{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ridepro worker-inbox envelope (rp-api / rp-admin / rp-web / rp-android / rp-ios / rp-qa)",
  "description": "Messages dispatched by the orchestrator into a worker inbox.",
  "version": "1.1",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "from",
    "to",
    "subject"
  ],
  "properties": {
    "type": {
      "enum": [
        "task",
        "question",
        "note",
        "approval-token",
        "approval-revoke",
        "contract-change",
        "rotate"
      ]
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-]*$",
      "description": "Any hyphen-separated alphanumeric identifier."
    },
    "from": {
      "const": "orchestrator"
    },
    "to": {
      "enum": [
        "api",
        "admin",
        "web",
        "android",
        "ios",
        "qa",
        "*"
      ]
    },
    "subject": {
      "type": "string",
      "minLength": 3
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-]*:(api|admin|web|android|ios|qa)$"
      },
      "description": "<task_id>:<worker> refs that must be complete before this task starts."
    },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Commands the worker must run before reporting type:result."
    },
    "wire_compat": {
      "enum": [
        "additive",
        "breaking"
      ],
      "description": "Required on type:contract-change."
    },
    "baseline_task_id": {
      "type": "string",
      "description": "Optional reference to a baseline task for comparison."
    },
    "body": {},
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Checklist of deliverables the worker must confirm before posting type:result."
    },
    "ui_verified_instructions": {
      "type": "string",
      "description": "Steps to manually verify the UI change in a browser (required when ui_verified is in required_checks)."
    },
    "affected_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Files this task is expected to touch."
    },
    "refs": {
      "type": "array"
    },
    "context": {
      "type": "string",
      "minLength": 1,
      "description": "One sentence explaining why this task exists."
    },
    "files": {
      "type": "object",
      "properties": {
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "description": "Per-task file scope."
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "run",
          "pass_condition"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "run": {
            "type": "string"
          },
          "pass_condition": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "description": "Executable checks with pass conditions."
    },
    "background": {
      "type": "string",
      "minLength": 1,
      "description": "Optional 2-3 sentences of deeper context — prior decisions, related tasks, what failed before."
    },
    "scope": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ],
      "description": "Complexity hint: small (<30 min), medium (30-90 min), large (>90 min, expect context rotation)."
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Per-task do-NOT rules the worker must obey even when they conflict with defaults."
    },
    "result_template": {
      "type": "object",
      "description": "Skeleton JSON the worker fills in for the result body; ensures required fields are present.",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "task"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "body"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "contract-change"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "wire_compat"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "approval-token"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "required": [
              "authorized_actions",
              "env",
              "scope_workers",
              "expires_at"
            ],
            "properties": {
              "authorized_actions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "string"
              },
              "scope_workers": {
                "type": "array",
                "minItems": 1
              },
              "expires_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "required": [
          "body"
        ]
      }
    }
  ],
  "additionalProperties": false
}
