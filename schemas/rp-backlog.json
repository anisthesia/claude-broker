{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ridepro rp-backlog envelope",
  "description": "Persistent deferred task register. NEVER purge this channel — it survives all sprint-boundary purges.",
  "type": "object",
  "required": ["type", "task_id", "subject"],
  "properties": {
    "type": { "enum": ["deferred", "deferred-resolved"] },
    "task_id": { "type": "string", "minLength": 3 },
    "from": { "enum": ["api", "admin", "web", "android", "ios", "qa", "orchestrator"] },
    "to": { "const": "orchestrator" },
    "subject": { "type": "string", "minLength": 3 },
    "body": { "type": "object" },
    "deferred_reason": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "deferred-resolved" } }, "required": ["type"] },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "required": ["resolved_in_sprint", "outcome"],
            "properties": {
              "resolved_in_sprint": { "type": "string" },
              "outcome": { "enum": ["promoted", "cancelled", "superseded"] }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
