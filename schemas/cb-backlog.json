{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claude-broker cb-backlog envelope",
  "description": "Persistent deferred task register for cb-namespace. NEVER purge this channel. Supports three message shapes: task envelopes, retrospectives, and deferred messages.",
  "oneOf": [
    {
      "type": "object",
      "title": "Task envelope (task, result, note, status, question)",
      "required": ["type", "task_id", "subject", "body", "from", "to"],
      "properties": {
        "type": { "enum": ["task", "result", "note", "status", "question"] },
        "task_id": { "type": "string", "minLength": 3 },
        "subject": { "type": "string", "minLength": 3 },
        "body": { "type": "object" },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "Retrospective",
      "required": ["type", "sprint", "dates", "workers", "tasks"],
      "properties": {
        "type": { "const": "retrospective" },
        "sprint": { "type": "string" },
        "dates": { "type": "object" },
        "workers": { "type": "array" },
        "tasks": { "type": "array" },
        "key_metrics": { "type": "object" },
        "backlog_deferred": { "type": "array" }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "title": "Deferred or deferred-resolved",
      "required": ["type", "task_id", "subject"],
      "properties": {
        "type": { "enum": ["deferred", "deferred-resolved"] },
        "task_id": { "type": "string", "minLength": 3 },
        "subject": { "type": "string", "minLength": 3 },
        "body": { "oneOf": [{ "type": "string" }, { "type": "object" }] },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "deferred_reason": { "type": "string" },
        "resolved_in_sprint": { "type": "string" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "deferred" } }, "required": ["type"] },
          "then": { "required": ["deferred_reason"] }
        },
        {
          "if": { "properties": { "type": { "const": "deferred-resolved" } }, "required": ["type"] },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "required": ["resolved_in_sprint", "outcome"],
                "properties": {
                  "resolved_in_sprint": { "type": "string" },
                  "outcome": { "enum": ["promoted", "cancelled", "superseded"] }
                }
              }
            }
          }
        }
      ]
    }
  ]
}
