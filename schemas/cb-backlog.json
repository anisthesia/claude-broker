{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claude-broker cb-backlog envelope",
  "description": "Persistent deferred task register for cb-namespace. NEVER purge this channel.",
  "type": "object",
  "required": ["type", "task_id", "subject"],
  "properties": {
    "type": { "enum": ["deferred", "deferred-resolved", "retrospective"] },
    "task_id": { "type": "string", "minLength": 3 },
    "from": {
      "type": "string",
      "minLength": 1,
      "description": "Worker or orchestrator that created this entry."
    },
    "to": { "type": "string" },
    "subject": { "type": "string", "minLength": 3 },
    "body": { "type": "object" },
    "deferred_reason": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "deferred" } }, "required": ["type"] },
      "then": { "required": ["deferred_reason"] }
    },
    {
      "if": { "properties": { "type": { "const": "deferred-resolved" } }, "required": ["type"] },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "required": ["resolved_in_sprint", "outcome"],
            "properties": {
              "resolved_in_sprint": { "type": "string" },
              "outcome": { "enum": ["promoted", "cancelled", "superseded"] }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
