{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dollex ERP worker-inbox envelope (dx-api / dx-web / dx-db / dx-qa)",
  "description": "Messages dispatched by the orchestrator into a worker inbox.",
  "type": "object",
  "required": ["type", "task_id", "from", "to", "subject"],
  "properties": {
    "type": {
      "enum": ["task", "question", "note", "approval-token", "approval-revoke", "contract-change", "rotate"]
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$",
      "description": "Format: <slug>-YYYY-MM-DD-<short-name>"
    },
    "from": { "const": "orchestrator" },
    "to": { "enum": ["api", "web", "db", "qa", "*"] },
    "subject": { "type": "string", "minLength": 3 },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+:(api|web|db|qa)$"
      },
      "description": "<task_id>:<worker> refs that must be complete before this task starts."
    },
    "required_checks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Commands the worker must run before reporting type:result."
    },
    "wire_compat": {
      "enum": ["additive", "breaking"],
      "description": "Required on type:contract-change."
    },
    "body": {},
    "refs": { "type": "array" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "contract-change" } }, "required": ["type"] },
      "then": { "required": ["wire_compat"] }
    },
    {
      "if": { "properties": { "type": { "const": "approval-token" } }, "required": ["type"] },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "required": ["authorized_actions", "env", "scope_workers", "expires_at"],
            "properties": {
              "authorized_actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "env": { "type": "string" },
              "scope_workers": { "type": "array", "minItems": 1 },
              "expires_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
