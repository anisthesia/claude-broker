{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dogsvilla dv-control envelope",
  "description": "Orchestrator broadcasts: contract changes, approval tokens, policy updates, rotation commands, consent relay.",
  "type": "object",
  "required": ["type", "task_id", "from", "to", "subject"],
  "properties": {
    "type": {
      "enum": [
        "contract-change",
        "approval-token",
        "approval-revoke",
        "note",
        "policy-update",
        "rotate",
        "reload",
        "consent-grant",
        "consent-deny",
        "ledger-snapshot"
      ]
    },
    "task_id": { "type": "string", "minLength": 3 },
    "from": { "type": "string", "minLength": 1, "description": "Dispatcher identity, typically 'orchestrator' or a domain orchestrator name." },
    "to": {
      "type": "string",
      "minLength": 1,
      "description": "Target: a worker name, domain orchestrator name ('platform-orch', 'consumer-orch', 'growth-orch', 'intel-orch'), or '*' for broadcast."
    },
    "subject": { "type": "string", "minLength": 3 },
    "wire_compat": { "enum": ["additive", "breaking"] },
    "body": {},
    "refs": { "type": "array" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "contract-change" } }, "required": ["type"] },
      "then": {
        "required": ["wire_compat"],
        "properties": {
          "body": {
            "type": "object",
            "required": ["before", "after", "affected_workers"],
            "properties": {
              "affected_workers": { "type": "array", "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "approval-token" } }, "required": ["type"] },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "required": ["authorized_actions", "env", "scope_workers", "expires_at"],
            "properties": {
              "authorized_actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "env": { "type": "string" },
              "scope_workers": { "type": "array", "minItems": 1 },
              "expires_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "approval-revoke" } }, "required": ["type"] },
      "then": {
        "required": ["body"],
        "properties": {
          "body": {
            "type": "object",
            "required": ["revokes_msg_id"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
