{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claude-broker cb-worker-inbox envelope",
  "description": "Messages dispatched into a cb- worker inbox (cb-core, cb-protocol-qa).",
  "type": "object",
  "required": ["type", "task_id", "from", "to", "subject"],
  "properties": {
    "type": {
      "enum": [
        "task",
        "question",
        "note",
        "approval-token",
        "approval-revoke",
        "consent-grant",
        "consent-deny",
        "rotate"
      ]
    },
    "task_id": {
      "type": "string",
      "minLength": 3,
      "description": "Format: cb-YYYY-MM-DD-<slug>, e.g. 'cb-2026-06-19-add-tool'."
    },
    "from": {
      "type": "string",
      "minLength": 1,
      "description": "Dispatcher identity: 'orchestrator' or 'infra-orch'."
    },
    "to": {
      "type": "string",
      "minLength": 1,
      "description": "Target worker: 'core', 'protocol-qa', or '*' for broadcast."
    },
    "subject": { "type": "string", "minLength": 3 },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "description": "<task_id>:<worker> that must have type:result on cb-status before this task starts."
      }
    },
    "required_checks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Checks the worker must run before posting type:result, e.g. ['test', 'committed']."
    },
    "body": {},
    "refs": { "type": "array" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "approval-token" } }, "required": ["type"] },
      "then": {
        "required": ["body"],
        "properties": {
          "body": {
            "type": "object",
            "required": ["authorized_actions", "env", "scope_workers", "expires_at"],
            "properties": {
              "authorized_actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "env": { "type": "string" },
              "scope_workers": { "type": "array", "minItems": 1 },
              "expires_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
