{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dogsvilla dv-status envelope",
  "description": "Worker firehose for status updates, task results, blockers, and notes back to the orchestrator.",
  "type": "object",
  "required": ["type", "task_id", "from", "to", "subject"],
  "properties": {
    "type": {
      "enum": ["status", "result", "question", "note", "contract-change", "handoff"]
    },
    "task_id": { "type": "string", "minLength": 3 },
    "from": { "enum": ["backend", "frontend", "customer-portal"] },
    "to": { "enum": ["orchestrator", "backend", "frontend", "customer-portal"] },
    "subject": { "type": "string", "minLength": 3 },
    "body": {},
    "refs": { "type": "array" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "const": "result" },
          "body": {
            "type": "object",
            "properties": { "production_touching": { "const": true } },
            "required": ["production_touching"]
          }
        },
        "required": ["type", "body"]
      },
      "then": {
        "properties": {
          "body": { "required": ["consent_basis"] }
        }
      }
    }
  ],
  "additionalProperties": false
}
