{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dogsvilla dv-status envelope",
  "description": "Worker firehose for status updates, task results, blockers, and notes back to the orchestrator.",
  "type": "object",
  "required": ["type", "task_id", "from", "to", "subject"],
  "properties": {
    "type": {
      "enum": ["status", "result", "question", "note", "contract-change", "handoff"]
    },
    "task_id": { "type": "string", "minLength": 3 },
    "from": {
      "type": "string",
      "minLength": 1,
      "description": "Worker identifier, e.g. 'backend', 'frontend', 'platform-orch', 'qa'."
    },
    "to": {
      "type": "string",
      "minLength": 1,
      "description": "Recipient identifier. 'root-orchestrator', a domain orchestrator ('platform-orch', 'consumer-orch', 'growth-orch', 'intel-orch'), a worker name, or '*' for broadcast."
    },
    "subject": { "type": "string", "minLength": 3 },
    "summary": {
      "type": "string",
      "description": "Required on type:result. Format: 'PASS — <≤30-word sentence>' / 'FAIL — …' / 'SKIP — …'. Used by check_result and orchestrator ledger closes."
    },
    "affected_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Source files touched by this task. REQUIRED on type:result when body.commits is non-empty. Used by sprint_file_conflicts to detect cross-worker add/add and edit/edit conflicts before the sprint-close merge script runs. Omitting this field creates a blind spot in conflict detection — the file may still conflict at merge time without warning."
    },
    "body": {},
    "refs": { "type": "array" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "result" } }, "required": ["type"] },
      "then": {
        "required": ["summary"],
        "properties": {
          "body": {
            "type": "object",
            "required": ["consent_basis"],
            "properties": {
              "consent_basis": {
                "type": "string",
                "description": "How consent was obtained. Use 'orchestrator-dispatch-only' for non-production tasks.",
                "examples": ["orchestrator-dispatch-only", "terminal-human", "approval-token:#<msg_id>", "sprint-envelope-with-token:#<msg_id>"]
              },
              "commits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["sha", "branch"],
                  "properties": {
                    "sha":     { "type": "string" },
                    "branch":  { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "result" },
          "body": {
            "type": "object",
            "properties": {
              "commits": { "type": "array", "minItems": 1 }
            },
            "required": ["commits"]
          }
        },
        "required": ["type", "body"]
      },
      "then": {
        "required": ["affected_files"],
        "properties": {
          "affected_files": { "minItems": 1 }
        }
      }
    }
  ],
  "additionalProperties": false
}
