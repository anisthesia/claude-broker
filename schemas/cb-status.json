{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claude-broker cb-status envelope",
  "description": "Worker firehose for status updates, task results, questions, and notes back to the orchestrator.",
  "type": "object",
  "required": ["type", "task_id", "from", "to", "subject"],
  "properties": {
    "type": {
      "enum": ["status", "result", "question", "note", "handoff"]
    },
    "task_id": { "type": "string", "minLength": 3 },
    "from": {
      "type": "string",
      "minLength": 1,
      "description": "Worker identifier: 'core' or 'protocol-qa'."
    },
    "to": {
      "type": "string",
      "minLength": 1,
      "description": "'orchestrator', 'infra-orch', or '*'."
    },
    "subject": { "type": "string", "minLength": 3 },
    "summary": {
      "type": "string",
      "description": "Required on type:result. Format: 'PASS — <≤30-word sentence>' / 'FAIL — …' / 'SKIP — …'."
    },
    "affected_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Source files touched by this task. Required on type:result when body.commits is non-empty."
    },
    "body": {},
    "refs": { "type": "array" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "result" } }, "required": ["type"] },
      "then": {
        "required": ["summary"],
        "properties": {
          "body": {
            "type": "object",
            "required": ["consent_basis"],
            "properties": {
              "consent_basis": {
                "type": "string",
                "description": "How consent was obtained. Use 'orchestrator-dispatch-only' for non-production tasks.",
                "examples": ["orchestrator-dispatch-only", "terminal-human", "approval-token:#<msg_id>"]
              },
              "commits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["sha", "branch"],
                  "properties": {
                    "sha":     { "type": "string" },
                    "branch":  { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "result" },
          "body": {
            "type": "object",
            "properties": { "commits": { "type": "array", "minItems": 1 } },
            "required": ["commits"]
          }
        },
        "required": ["type", "body"]
      },
      "then": {
        "required": ["affected_files"],
        "properties": { "affected_files": { "minItems": 1 } }
      }
    }
  ],
  "additionalProperties": false
}
