# Port the broker listens on
PORT=8080

# Shared secret — both Claude Code clients must send this as a Bearer token.
# Leave blank to disable auth (NOT recommended once exposed to the internet).
SHARED_SECRET=change-me-to-a-long-random-string

# SQLite file (created on first run)
DB_PATH=./broker.db

# Optional: tmux session name for worker management.
# When set, start_worker launches each worker in a named tmux window (window
# name = worker name) instead of a background subprocess writing to a log file.
# stop_worker kills the window; list_workers checks live window existence.
# Leave blank (default) to use the original subprocess + log-file mode.
# WORKERS_TMUX_SESSION=claude-broker
